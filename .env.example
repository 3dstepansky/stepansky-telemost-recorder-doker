# --- НАСТРОЙКИ STEPANSKY TELEMOST (ZERO COST CORE) ---

# Отображаемое имя бота на встрече (Гостевой вход)
BOT_DISPLAY_NAME="Бот-Ассистент"

# API Ключ Groq (Для бесплатной транскрибации Whisper и Llama-3)
# Получить бесплатно здесь: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Режим работы ( headless=true для Docker/Сервера, headless=false для Windows-окна )
HEADLESS=true

# Настройки S3 (Для Milestone 3: Авто-выгрузка в облако)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
